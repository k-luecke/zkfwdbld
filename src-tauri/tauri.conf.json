{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zkfwdbld",
  "version": "0.1.0",
  "identifier": "com.zkfwdbld.desktop",
  "build": {
    "beforeBuildCommand": {
      "script": "node app/generate_packet_json.mjs",
      "wait": true
    },
    "beforeDevCommand": {
      "script": "node app/generate_packet_json.mjs",
      "wait": true
    },
    "frontendDist": "../app/static"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "zkfwdbld",
        "width": 1400,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "category": "DeveloperTool",
    "icon": ["icons/icon.png"]
  }
}
